# ═════════════════════════════════════════════════════════════════════════════
# LogSystem - Vercel Serverless Environment Configuration
# 
# This file contains the minimal environment variables required for Vercel deployment.
# Copy these values to your Vercel project environment variables.
# 
# ⚠️ IMPORTANT: Never commit real secrets to git.
# ═════════════════════════════════════════════════════════════════════════════

# ─ DATABASE (REQUIRED) ───────────────────────────────────────────────────────────
# MySQL/Aiven connection details
DB_HOST=mysql-xxx.aivencloud.com
DB_PORT=21661
DB_USER=avnadmin
DB_PASSWORD=your_mysql_password
DB_NAME=logsystem
DB_SSL=true
DB_SSL_CA_BASE64=your_base64_encoded_ca_certificate
DB_SSL_REJECT_UNAUTHORIZED=false
DB_CONNECTION_LIMIT=5

# ─ SECURITY (REQUIRED) ───────────────────────────────────────────────────────────
# Generate using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=your_session_secret_min_32_chars
CSRF_SECRET=your_csrf_secret_min_32_chars

# ─ REDIS (OPTIONAL) ───────────────────────────────────────────────────────────────
# If using Aiven Redis or similar
REDIS_URL=redis://user:password@host:port

# ─ VERCEL-SPECIFIC SETTINGS ────────────────────────────────────────────────────────
# These are automatically set by Vercel, but can be overridden if needed
# NODE_ENV=production (auto-set by Vercel)
# PORT=3000 (auto-set by Vercel)
# VERCEL=1 (auto-set by Vercel)

# ─ DISABLED ON VERCEL ─────────────────────────────────────────────────────────────
# Background jobs are automatically disabled on Vercel
# START_BACKGROUND_JOBS=false (auto-detected)
# File uploads limited to 4.5 MB per request
# UPLOAD_MAX_SIZE=4500000 (recommended for Vercel)

# ─ OPTIONAL SETTINGS ───────────────────────────────────────────────────────────────
LOG_LEVEL=info
BCRYPT_ROUNDS=12
IMPORT_BATCH_SIZE=500
ALERT_EVAL_INTERVAL=60000
SEARCH_RATE_MAX=100
IMPORT_RATE_MAX=10
