# Caddyfile — Caddy reverse proxy avec TLS automatique
# Remplacez votre-domaine.com par votre vrai domaine

votre-domaine.com {
    # TLS automatique via Let's Encrypt (Caddy gère tout)
    tls {
        protocols tls1.2 tls1.3
    }

    # En-têtes de sécurité
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Frame-Options "DENY"
        X-Content-Type-Options "nosniff"
        -Server
    }

    # SSE — désactiver le buffering pour les Server-Sent Events
    @sse path /api/alerts/stream /api/events/stream
    handle @sse {
        reverse_proxy localhost:3000 {
            flush_interval -1
            transport http {
                response_header_timeout 0
            }
        }
    }

    # Reste de l'application
    reverse_proxy localhost:3000 {
        health_uri /api/health
        health_interval 30s
    }
}
