# ─── Environnement ────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ─── Base de données MySQL ────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=logsystem
DB_SSL=false
# DB_SSL_CA_PATH=./ca.pem        # Chemin vers le CA pour Aiven
# DB_CONNECTION_LIMIT=10
# DB_QUEUE_LIMIT=0

# ─── Redis (optionnel — mode dégradé si absent) ───────────────────────────────
# REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=

# ─── Sécurité — OBLIGATOIRE ──────────────────────────────────────────────────
# Générer avec: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=CHANGE_ME_WITH_A_LONG_RANDOM_SECRET_AT_LEAST_32_CHARS

# ─── Upload & Import ──────────────────────────────────────────────────────────
UPLOAD_MAX_SIZE=52428800       # 50MB
IMPORT_BATCH_SIZE=500

# ─── Surveillance fichiers (Watch Log — optionnel) ────────────────────────────
# WATCH_DIRS=./logs
# WATCH_DIR_USER_MAP=./logs:user_id_ici

# ─── Alertes & Sécurité ───────────────────────────────────────────────────────
BCRYPT_ROUNDS=12
ALERT_EVAL_INTERVAL=60000

# ─── Next.js ──────────────────────────────────────────────────────────────────
NEXT_TELEMETRY_DISABLED=1
