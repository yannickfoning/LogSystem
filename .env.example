# ═══════════════════════════════════════════════════════════════
# LOGSYSTEM FUSION — Variables d'environnement
# Copiez ce fichier en .env et remplissez les valeurs
# ═══════════════════════════════════════════════════════════════

# ─── Application ─────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ─── Base de données MySQL (Aiven Cloud) ─────────────────────
# Configuration pour Aiven MySQL (service managé)
DB_HOST=mysql-xxx.aivencloud.com
DB_PORT=21665
DB_USER=avnadmin
DB_PASSWORD=VOTRE_MOT_DE_PASSE_AIVEN
DB_NAME=defaultdb
DB_SSL=true

# Alternative: URL de connexion complète (optionnel)
# DATABASE_URL=mysql://avnadmin:VOTRE_MOT_DE_PASSE@mysql-xxx.aivencloud.com:21665/defaultdb?ssl=true

# ─── Sécurité — OBLIGATOIRE ──────────────────────────────────
# Générer avec: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=changer_ceci_avec_au_moins_64_caracteres_aleatoires_generes_par_crypto

# ─── Upload & Import ──────────────────────────────────────────
UPLOAD_DIR=/tmp/logsystem-uploads
UPLOAD_MAX_SIZE=52428800
IMPORT_BATCH_SIZE=500

# ─── Surveillance fichiers (Watch Log — optionnel) ────────────
# Laisser vide pour désactiver
# WATCH_DIRS=./logs,./app-logs
# WATCH_DIR_USER_MAP=./logs:user_id_ici

# ─── Rétention automatique ────────────────────────────────────
# Heure d'exécution de la rétention (0-23)
RETENTION_CRON_HOUR=3

# ─── Alertes ──────────────────────────────────────────────────
BCRYPT_ROUNDS=12
ALERT_EVAL_INTERVAL=60000

# ─── Déploiement ─────────────────────────────────────────────
# URL publique de l'app (pour CORS/redirections)
NEXT_PUBLIC_APP_URL=https://votre-domaine.com
