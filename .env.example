PORT=3001
NODE_ENV=development
SESSION_SECRET=<change-me-to-a-random-64-char-string>
CSRF_SECRET=<change-me-to-a-random-32-char-string>
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=log
DB_CONNECTION_LIMIT=10
DB_SSL=false
# DB_SSL_CA_PATH=/absolute/path/to/ca.pem
# DB_SSL_REJECT_UNAUTHORIZED=true
BCRYPT_ROUNDS=12
UPLOAD_MAX_SIZE=52428800
IMPORT_BATCH_SIZE=500
RAR_EXTRACTOR=
WATCH_DIRS=./logs
RETENTION_CRON_HOUR=3
ALERT_EVAL_INTERVAL=60000

# BE-02: Redis (optionnel — améliore les performances du cache)
REDIS_URL=redis://localhost:6379
