# ═════════════════════════════════════════════════════════════════════════════
# LogSystem - Environment Configuration (.env.example)
# 
# ⚠️ IMPORTANT: NEVER commit secrets to git. Use .env for local development only.
# For production/Vercel, configure environment variables in the platform UI.
# 
# Generated: 2026-06-19
# Version: 6.0.0
# ═════════════════════════════════════════════════════════════════════════════

# ─ NODE & APPLICATION ──────────────────────────────────────────────────────────
# NODE_ENV: development | production
# Default: development
NODE_ENV=development

# PORT: Express server port (Vercel ignores this, uses 3000 by default)
# Default: 3001
PORT=3001

# APP_VERSION: Application version (for API responses)
# Default: 6.0.0
# APP_VERSION=6.0.0

# ─ LOGGING ─────────────────────────────────────────────────────────────────────
# LOG_LEVEL: debug | info | warn | error | fatal
# Default: info
# LOG_LEVEL=info

# ─ DATABASE - MySQL / Aiven ───────────────────────────────────────────────────
# Required for all environments.
# Example Aiven credentials below:

# DB_HOST: MySQL server hostname
# Example: mysql-xxx.aivencloud.com
DB_HOST=localhost

# DB_PORT: MySQL server port
# Default: 3306
# Aiven typically uses: 21661
DB_PORT=3306

# DB_USER: MySQL username
# Example: avnadmin
DB_USER=root

# DB_PASSWORD: MySQL password
# ⚠️ DO NOT commit real passwords to git
DB_PASSWORD=

# DB_NAME: Database name
# Default: logsystem
DB_NAME=logsystem

# DB_SSL: Enable SSL connection to MySQL
# For Aiven: "true"
# For local MySQL: "false"
# Default: false
DB_SSL=false

# DB_SSL_CA: CA certificate PEM content (inline — for Vercel/serverless)
# Copy from Aiven: Service → Connection information → CA certificate
# DB_SSL_CA=-----BEGIN CERTIFICATE-----\nMIID...\n-----END CERTIFICATE-----

# DB_SSL_CA_BASE64: Same CA cert, base64-encoded (recommended on Vercel — one line, no newlines)
# Generate: base64 -i ca.pem | tr -d '\n'   (Linux/macOS)
# Generate: [Convert]::ToBase64String([IO.File]::ReadAllBytes("ca.pem"))   (PowerShell)
# DB_SSL_CA_BASE64=

# DB_SSL_CA_PATH: Path to CA certificate file (Render/local only — not available on Vercel)
# DB_SSL_CA_PATH=/path/to/ca.pem

# DB_SSL_REJECT_UNAUTHORIZED: Reject self-signed / unverified certificates
# Default: true (secure). On Vercel without CA: set to "false" as quick fix for Aiven SSL.
# Prefer DB_SSL_CA or DB_SSL_CA_BASE64 instead for full certificate validation.
# DB_SSL_REJECT_UNAUTHORIZED=true

# DB_CONNECTION_LIMIT: Max pool connections
# Default: 10
# DB_CONNECTION_LIMIT=10

# DB_QUEUE_LIMIT: Max queued connection requests
# Default: 0 (unlimited)
# DB_QUEUE_LIMIT=0

# ─ REDIS (OPTIONAL - Cache Service) ────────────────────────────────────────────
# Redis is optional. If not configured, app runs in degraded mode.
# For Aiven Redis:

# REDIS_URL: Full Redis URL (takes precedence over REDIS_HOST/PORT/PASSWORD)
# Example: redis://user:password@host:port
# REDIS_URL=

# REDIS_HOST: Redis server hostname (ignored if REDIS_URL is set)
# Default: localhost
# REDIS_HOST=localhost

# REDIS_PORT: Redis server port (ignored if REDIS_URL is set)
# Default: 6379
# REDIS_PORT=6379

# REDIS_PASSWORD: Redis password (ignored if REDIS_URL is set)
# REDIS_PASSWORD=

# REDIS_DB: Redis database number (ignored if REDIS_URL is set)
# Default: 0
# REDIS_DB=0

# ─ SECURITY - REQUIRED ────────────────────────────────────────────────────────
# ⚠️ MANDATORY: These secrets must be changed for production.
# Generate using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"

# SESSION_SECRET: Express session secret
# Minimum 32 characters recommended (64+ recommended for production)
SESSION_SECRET=REPLACE_WITH_RANDOM_SECRET_AT_LEAST_32_CHARACTERS

# CSRF_SECRET: CSRF protection secret
# Minimum 32 characters recommended (64+ recommended for production)
CSRF_SECRET=REPLACE_WITH_ANOTHER_RANDOM_SECRET_AT_LEAST_32_CHARACTERS

# ─ AUTHENTICATION & SECURITY ──────────────────────────────────────────────────
# BCRYPT_ROUNDS: Bcrypt hashing rounds (higher = slower but more secure)
# Default: 12
# Range: 10-14 recommended
# BCRYPT_ROUNDS=12

# ─ UPLOAD & IMPORT LIMITS ──────────────────────────────────────────────────────
# UPLOAD_MAX_SIZE: Maximum file upload size (bytes)
# Default: 524288000 (500 MB)
# ⚠️ Vercel Serverless has 4.5 MB hard limit per request
# For Vercel, use smaller limits
# UPLOAD_MAX_SIZE=524288000

# UPLOAD_MAX_FILES: Maximum number of files in a single upload
# Default: 10
# UPLOAD_MAX_FILES=10

# IMPORT_MAX_SIZE: Alternative to UPLOAD_MAX_SIZE (for backward compatibility)
# Not recommended; use UPLOAD_MAX_SIZE instead
# IMPORT_MAX_SIZE=524288000

# IMPORT_BATCH_SIZE: Number of logs to insert per batch
# Default: 500
# Higher = faster import but more memory
# IMPORT_BATCH_SIZE=500

# ERROR_RETURN_GAP_DAYS: Days to return error logs
# Used for error reporting and diagnostics
# Default: 7
# ERROR_RETURN_GAP_DAYS=7

# ─ FILE WATCH & AUTOMATIC LOG IMPORT (OPTIONAL) ──────────────────────────────
# ⚠️ These are DISABLED on Vercel (START_BACKGROUND_JOBS=false)
# Only use on self-hosted or Render deployments.

# WATCH_DIRS: Comma-separated directories to watch for new log files
# Example: ./logs,/var/log/app
# Default: ./logs
# WATCH_DIRS=./logs

# WATCH_DIR_USER_MAP: Map directories to user IDs for auto-import
# Format: /path/to/dir:user_id,/another/dir:other_user_id
# Example: ./logs:1,/var/log:2
# WATCH_DIR_USER_MAP=

# ─ BACKGROUND JOBS & SERVICES ────────────────────────────────────────────────
# ⚠️ IMPORTANT: Disabled on Vercel (START_BACKGROUND_JOBS auto-set to false).

# START_BACKGROUND_JOBS: Enable alert engine, retention scheduler, and watcher
# Default: true (disabled on Vercel)
# START_BACKGROUND_JOBS=true

# RUN_MIGRATIONS_ON_START: Automatically run pending database migrations on startup
# Default: true
# RUN_MIGRATIONS_ON_START=true

# ─ ALERTING ENGINE ────────────────────────────────────────────────────────────
# ALERT_EVAL_INTERVAL: Milliseconds between alert rule evaluations
# Default: 60000 (60 seconds)
# Higher = less frequent checks, lower database load
# ALERT_EVAL_INTERVAL=60000

# ALERT_DEBOUNCE_MS: Milliseconds to debounce alert notifications per user
# Prevents alert spam for the same rule
# Default: 2000
# ALERT_DEBOUNCE_MS=2000

# SAFETY_INTERVAL: Minimum milliseconds between alert checks (safety limiter)
# Default: same as ALERT_EVAL_INTERVAL
# SAFETY_INTERVAL=60000

# ─ LOG RETENTION & CLEANUP ────────────────────────────────────────────────────
# RETENTION_CRON_HOUR: Hour (0-23) to run retention cleanup job
# Default: 3 (3 AM UTC)
# RETENTION_CRON_HOUR=3

# ─ LOCALE & INTERNATIONALIZATION ───────────────────────────────────────────────
# LOG_DATE_LOCALE: Locale for parsing log dates
# Default: fr (French)
# Other options: en (English), de (German), es (Spanish), etc.
# LOG_DATE_LOCALE=fr

# ─ ARCHIVE EXTRACTION (OPTIONAL) ──────────────────────────────────────────────
# RAR_EXTRACTOR: System command to extract RAR files
# Default: auto-detect (unrar or 7z)
# Examples: unrar, 7z, WinRAR (Windows)
# Only set if auto-detection fails
# RAR_EXTRACTOR=unrar

# ─ RATE LIMITING ──────────────────────────────────────────────────────────────
# IMPORT_RATE_MAX: Max requests per 15 minutes for import endpoint
# Default: 10
# IMPORT_RATE_MAX=10

# SEARCH_RATE_MAX: Max requests per 15 minutes for search endpoint
# Default: 100
# SEARCH_RATE_MAX=100

# ─ DEFAULT USERS (SETUP ONLY) ──────────────────────────────────────────────
# Used by create-default-users.js script during initial setup
# Not needed if users already exist in database

# DEFAULT_ADMIN_EMAIL: Initial admin user email
# DEFAULT_ADMIN_EMAIL=admin@logsystem.local

# DEFAULT_ADMIN_PASSWORD: Initial admin user password
# ⚠️ Change immediately after first login
# DEFAULT_ADMIN_PASSWORD=Admin@1234

# DEFAULT_ADMIN_NAME: Initial admin display name
# DEFAULT_ADMIN_NAME=Administrateur

# DEFAULT_USER_EMAIL: Initial regular user email
# DEFAULT_USER_EMAIL=user@logsystem.local

# DEFAULT_USER_PASSWORD: Initial regular user password
# ⚠️ Change immediately after first login
# DEFAULT_USER_PASSWORD=User@1234

# DEFAULT_USER_NAME: Initial regular user display name
# DEFAULT_USER_NAME=Utilisateur Standard

# ═════════════════════════════════════════════════════════════════════════════
# VERCEL-SPECIFIC NOTES
# ═════════════════════════════════════════════════════════════════════════════
#
# 1. Vercel automatically sets: NODE_ENV=production, PORT=3000, VERCEL=1
#
# 2. Background jobs are automatically disabled on Vercel
#    (START_BACKGROUND_JOBS=false)
#
# 3. File uploads are limited to request body size (usually 4.5 MB)
#    Don't set UPLOAD_MAX_SIZE > 4.5 MB on Vercel
#
# 4. Database connection pooling may need adjustment:
#    - Set DB_CONNECTION_LIMIT=5 for Vercel
#    - Each serverless function gets its own connection pool
#
# 5. Ensure all database environment variables are set in Vercel dashboard:
#    - DB_HOST, DB_PORT, DB_USER, DB_PASSWORD, DB_NAME
#    - DB_SSL, DB_SSL_CA / DB_SSL_CA_BASE64 (Vercel) or DB_SSL_CA_PATH (Render/local)
#    - DB_SSL_REJECT_UNAUTHORIZED=false (fix rapide SSL Aiven sur Vercel)
#    - SESSION_SECRET, CSRF_SECRET
#
# ═════════════════════════════════════════════════════════════════════════════
