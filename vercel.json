{
  "version": 2,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/server.js"
    },
    {
      "source": "/health",
      "destination": "/server.js"
    },
    {
      "source": "/(.*)",
      "destination": "/server.js"
    }
  ],
  "functions": {
    "server.js": {
      "maxDuration": 60,
      "memory": 1024,
      "includedFiles": [
        "config/**",
        "lib/**",
        "lib/assets/**",
        "middleware/**",
        "routes/**",
        "services/**",
        "workers/**",
        "public/**",
        "db/**",
        "migrations/**"
      ]
    }
  }
}
